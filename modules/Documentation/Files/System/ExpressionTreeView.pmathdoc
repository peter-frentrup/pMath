           SectionGenerated -> True, SectionLabel -> "out [2]:")}, All)}, 1), 
      SectionGroup({Section("Possible Issues", "ExampleSection"), 
        Section("Compound heads are not laid out as trees:", "ExampleText"), 
        SectionGroup({
          Section(BoxData({"ExpressionTreeView", "(", {
